{
  "version": 2,
  "builds": [
    {
      "src": "rag-frontend/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist",
        "srcDir": "rag-frontend"
      }
    },
    {
      "src": "api/[...path].py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/[...path].py"
    },
    {
      "src": "/(.*)",
      "dest": "/rag-frontend/$1"
    }
  ]
}